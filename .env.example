# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# is injected into the bot container at runtime via `env_file:` in
# docker-compose.yml — never commit real keys, and never bake them into the
# Dockerfile.

# --- Discord (required) ---
DISCORD_TOKEN=your-discord-bot-token

# --- Channel IDs for scheduled pushes (optional; blank/0 disables) ---
MARKET_CHANNEL_ID=0
ALERT_CHANNEL_ID=0
NEWS_CHANNEL_ID=0

# --- External data / LLM APIs (optional per feature) ---
DEEPSEEK_API_KEY=your-deepseek-api-key
JIN10_API_KEY=your-jin10-mcp-token
NEWS_API_KEY=your-newsapi-key
FRED_API_KEY=your-fred-api-key
FMP_API_KEY=your-fmp-api-key

# --- Monitoring (optional) ---
# Port the bot exposes Prometheus metrics on (scraped as bot:9091 by Prometheus).
METRICS_PORT=9091
# Optional LLM cost estimation, USD per 1,000,000 tokens. Leave at 0 to disable
# the llm_cost_usd_total metric.
LLM_PRICE_PROMPT_PER_1M=0
LLM_PRICE_COMPLETION_PER_1M=0
